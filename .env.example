# ============================================
# SRE Agent — Environment Configuration
# ============================================

# === Azure Cosmos DB NoSQL ===
# Get from Azure Portal → Cosmos DB → Keys
COSMOS_ENDPOINT="https://your-account.documents.azure.com:443/"
COSMOS_KEY="your-cosmos-key-here"
COSMOS_DATABASE="sre_agent_db"

# === Google Gemini ===
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-3-flash-preview"

# === Observability (Langfuse — optional) ===
# Get from https://cloud.langfuse.com → Settings → API Keys
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"

# === App ===
APP_ENV="development"
APP_PORT="8000"
APP_WORKERS="1"
LOG_LEVEL="INFO"
APP_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
APP_ADMIN_API_KEY="change-me"
APP_DISABLE_ADMIN_ENDPOINTS="false"
APP_REQUIRE_INDEX_READY="false"
APP_ENABLE_DOCS="true"

# === Runtime hardening ===
APP_MAX_UPLOAD_BYTES="5242880"

# === Indexer ===
ESHOP_REPO_URL="https://github.com/dotnet/eShop.git"
ESHOP_CACHE_DIR=".eshop_cache"
